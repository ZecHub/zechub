{
  "name": "@zecpass/sdk-node",
  "version": "0.1.0",
  "description": "Node.js SDK for ZecPass — server-side Zcash authentication verification",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.mjs", "require": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": { "tsup": "^8.3.5", "typescript": "^5.7.3" },
  "license": "MIT"
}
